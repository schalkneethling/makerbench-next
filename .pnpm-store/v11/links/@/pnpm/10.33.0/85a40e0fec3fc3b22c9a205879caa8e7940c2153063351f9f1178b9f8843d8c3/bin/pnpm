#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/Users/schalkneethling/dev/opensource/makerbench-next/.pnpm-store/v11/links/@/pnpm/10.33.0/85a40e0fec3fc3b22c9a205879caa8e7940c2153063351f9f1178b9f8843d8c3/node_modules/pnpm/bin/pnpm.cjs
