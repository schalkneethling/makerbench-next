{
  "name": "makerbench-next",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:css": "stylelint \"**/*.css\" --ignore-path .gitignore",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.functions.json --noEmit",
    "quality": "pnpm format && pnpm lint && pnpm lint:css && pnpm typecheck && pnpm test && pnpm build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "migrate:makerbench-turso": "tsx scripts/import-makerbench-turso.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@netlify/functions": "^5.2.1",
    "@sentry/node": "^10.56.0",
    "@supabase/supabase-js": "^2.106.2",
    "@varlock/1password-plugin": "^1.1.0",
    "cheerio": "^1.1.2",
    "cloudinary": "^2.10.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "valibot": "^1.4.1",
    "varlock": "^0.7.4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.1.2",
    "@varlock/vite-integration": "^0.2.10",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "^3.2.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.2",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^8.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
